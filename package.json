{
   "name": "elsass-compta",
   "version": "1.0.0",
   "private": true,
   "engines": {
      "node": ">=26.0.0"
   },
   "scripts": {
      "dev": "next dev --turbopack",
      "build": "next build && next-sitemap",
      "start": "next start",
      "lint": "next lint",
      "sitemap": "next-sitemap",
      "dev:docker": "concurrently -k \"PORT=3004 node --watch server.js\" \"npx wait-on -t 10000 http://localhost:3004 && npx browser-sync start -c bs-config.docker.js\"",
      "docker:build": "docker compose -f docker-compose.yml build",
      "docker:push": "docker compose -f docker-compose.yml push",
      "docker:deploy": "docker compose -f docker-compose.yml build && docker compose -f docker-compose.yml push"
   },
   "dependencies": {
      "@radix-ui/react-slot": "^1.2.3",
      "@socialgouv/matomo-next": "^1.11.0",
      "@tailwindcss/postcss": "^4.1.8",
      "@tailwindcss/typography": "^0.5.16",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "framer-motion": "^12.16.0",
      "i": "^0.3.7",
      "lucide-react": "^0.511.0",
      "marked": "^15.0.12",
      "next": "^15.5.12",
      "next-sitemap": "^4.2.3",
      "postcss": "^8.5.4",
      "react": "^19.0.1",
      "react-dom": "^19.0.1",
      "react-hook-form": "^7.57.0",
      "react-icons": "^5.5.0",
      "resend": "^4.5.2",
      "tailwind-merge": "^3.3.0",
      "tailwindcss": "^4.1.8"
   },
   "devDependencies": {
      "tw-animate-css": "^1.3.3"
   }
}
